# ============================================================
# Border City Boxing — Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# PostgreSQL password for the Docker-managed database
DB_PASSWORD=change_me_to_something_secret

# Secret code required to register as an admin
ADMIN_CODE=BCB-ADMIN-2024

# Secret code required to register as a coach
COACH_CODE=BCB-COACH-2024

# Host port to expose the app on (default: 80)
APP_PORT=80
