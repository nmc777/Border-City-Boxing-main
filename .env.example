# ============================================================
# Border City Boxing — Environment Variables
# Copy this file to .env and fill in real values. Never commit .env.
# ============================================================

# PostgreSQL connection string
DATABASE_URL=postgres://postgres@localhost:5432/postgres

# API server port
PORT=8080

# development | production
NODE_ENV=development

# Secret codes required to register as admin / coach (CHANGE THESE)
ADMIN_CODE=changeme
COACH_CODE=changeme

# Square — get from https://developer.squareup.com/apps
# Use sandbox values in dev, production values when going live
SQUARE_ACCESS_TOKEN=
SQUARE_APPLICATION_ID=
SQUARE_ENVIRONMENT=sandbox
# HMAC signature key (Developer Dashboard → Webhooks → Signature key)
SQUARE_WEBHOOK_SIGNATURE_KEY=
# Public HTTPS URL Square will POST events to (must match the URL configured in the dashboard)
SQUARE_WEBHOOK_NOTIFICATION_URL=https://your-domain.example/api/payments/webhook

# Public URL of the deployed app (used in password-reset emails, webhook URLs, etc.)
APP_URL=http://localhost:5000

# Cookie signing secret for production. Generate with: openssl rand -hex 32
SESSION_SECRET=change-me-in-prod

# AWS SES (transactional email — password resets, receipts)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
EMAIL_FROM="Border City Boxing <no-reply@your-domain.example>"

# Where new-membership signup notifications are sent. Leave empty to skip.
# This must be a SES-verified address while you're in the SES sandbox; once
# you have production access it can be any address.
ADMIN_EMAIL=

# Mailchimp (newsletter signup)
MAILCHIMP_API_KEY=
MAILCHIMP_AUDIENCE_ID=
MAILCHIMP_SERVER_PREFIX=

# Logging
LOG_LEVEL=info

# Docker-only (used by docker-compose.yml)
DB_PASSWORD=change_me_to_something_secret
APP_PORT=80
