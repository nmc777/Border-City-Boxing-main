{
  "version": 2,
  "buildCommand": "pnpm install --frozen-lockfile && pnpm --filter @workspace/api-server run build && PORT=5000 BASE_PATH=/ pnpm --filter @workspace/boxing-club run build",
  "outputDirectory": "artifacts/boxing-club/dist/public",
  "functions": {
    "api/server.ts": {
      "runtime": "@vercel/node@5",
      "includeFiles": "artifacts/api-server/dist/**"
    }
  },
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/server.ts"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ],
  "env": {
    "NODE_ENV": "production",
    "PORT": "3000",
    "BASE_PATH": "/",
    "DATABASE_URL": "@database-url",
    "ADMIN_CODE": "@admin-code",
    "COACH_CODE": "@coach-code"
  }
}
