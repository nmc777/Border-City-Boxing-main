# Frontend environment variables — copy to .env and fill in real values
# These are PUBLIC values (not secrets) and are baked into the build at compile time

# Square Web Payments SDK
# Get from: https://developer.squareup.com/apps
VITE_SQUARE_APPLICATION_ID=your-sandbox-app-id
VITE_SQUARE_LOCATION_ID=your-sandbox-location-id

# Geoapify address autocomplete API
# Get from: https://www.geoapify.com/
VITE_GEOAPIFY_API_KEY=your-geoapify-api-key
