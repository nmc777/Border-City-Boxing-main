# ============================================================
# Docker Configuration for Border City Boxing
# Replace all <nmcdebug> values with your actual configuration
# ============================================================

FROM node:20-alpine AS base
RUN npm install -g pnpm

# ---- Install dependencies ----
FROM base AS deps
WORKDIR /app
COPY pnpm-workspace.yaml pnpm-lock.yaml .npmrc package.json ./
COPY artifacts/api-server/package.json ./artifacts/api-server/
COPY artifacts/boxing-club/package.json ./artifacts/boxing-club/
COPY lib/db/package.json ./lib/db/
COPY lib/api-zod/package.json ./lib/api-zod/
COPY lib/api-client-react/package.json ./lib/api-client-react/
COPY lib/replit-auth-web/package.json ./lib/replit-auth-web/
COPY lib/api-spec/package.json ./lib/api-spec/
RUN pnpm install --frozen-lockfile

# ---- Build backend ----
FROM deps AS build-api
WORKDIR /app
COPY . .
RUN pnpm --filter @workspace/api-server run build

# ---- Build frontend ----
FROM deps AS build-frontend
WORKDIR /app
COPY . .
ARG PORT=5000
ARG BASE_PATH=/
ENV PORT=$PORT
ENV BASE_PATH=$BASE_PATH
RUN pnpm --filter @workspace/boxing-club run build

# ---- Production image ----
FROM node:20-alpine AS production
WORKDIR /app

# Install only production runtime needs
RUN npm install -g pnpm

COPY --from=build-api /app/artifacts/api-server/dist ./artifacts/api-server/dist
COPY --from=build-api /app/node_modules ./node_modules
COPY --from=build-api /app/artifacts/api-server/node_modules ./artifacts/api-server/node_modules
COPY --from=build-frontend /app/artifacts/boxing-club/dist/public ./artifacts/boxing-club/dist/public

# ---- Environment Variables ----
# Replace <nmcdebug> with your actual values

ENV NODE_ENV=production

# Database connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DBNAME
ENV DATABASE_URL=<nmcdebug>

# Port the API server listens on (keep 3000 unless you change the nginx config)
ENV PORT=3000

# Admin registration code - change this to something secret
ENV ADMIN_CODE=<nmcdebug>

# Coach registration code - change this to something secret
ENV COACH_CODE=<nmcdebug>

# ---- Expose ports ----
# API server port
EXPOSE 3000
# Frontend port (served via nginx or another static file server)
EXPOSE 80

# ---- Start command ----
CMD ["node", "--enable-source-maps", "artifacts/api-server/dist/index.mjs"]

# ============================================================
# NGINX config (save as nginx.conf next to this Dockerfile)
# to serve the frontend and proxy /api to the Node server:
#
# server {
#   listen 80;
#   root /app/artifacts/boxing-club/dist/public;
#   index index.html;
#
#   location /api/ {
#     proxy_pass http://localhost:3000/api/;
#     proxy_http_version 1.1;
#     proxy_set_header Host $host;
#   }
#
#   location / {
#     try_files $uri $uri/ /index.html;
#   }
# }
# ============================================================
